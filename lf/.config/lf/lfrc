        bat ~/.config/lf/maps
        read ans
    }}


# this send to lf screen 
cmd mkFile %{{
  printf "File Name: "
  read ans
  touch $ans
}}



cmd chMod %{{
    printf ":"
    read ans
    
    files=$(printf "$fx" | tr '\n' ';')
    while [ "$files" ]; do
        file=${files%%;*}
        chmod $ans "$(basename "$file")"
        if [ "$files" = "$file" ]; then
            files=''
        else
            files="${files#*;}"
        fi
    done
}}

