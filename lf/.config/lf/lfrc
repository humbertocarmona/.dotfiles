# Custom Functions
cmd open ${{
    case $(file --mime-type "$f" -bL) in
        text/*|application/json) $EDITOR "$f";;
        *) xdg-open "$f" ;;
    esac
}}


# move current file or selected files to trash folder
# (also see 'man mv' for backup/overwrite options)
#cmd trash-put %set -f; mv $fx ~/.local/share/Trash/files


# Trash cli bindings
cmd trash ${{
  files=$(printf "$fx" | tr '\n' ';')
  while [ "$files" ]; do
    # extract the substring from start of string up to delimiter.
    # this is the first "element" of the string.
    file=${files%%;*}

    #mv $(basename "$file") ~/.local/share/Trash/files
    trash-put "$(basename "$file")"
    # if there's only one element left, set `files` to an empty string.
    # this causes us to exit this `while` loop.
    # else, we delete the first "element" of the string from files, and move onto
    # the next.
    if [ "$files" = "$file" ]; then
      files=''
    else
      files="${files#*;}"
    fi
  done
}}

cmd clear_trash %trash-empty

cmd restore_trash ${{
  trash-restore
}}


# define a custom 'delete' command
cmd delete ${{
     set -f
     printf "$fx\n"
     printf "delete?[y/n]"
     read ans
     [ $ans = "y" ] && rm -rf $fx
}}

cmd mkDir ${{
  printf "Directory Name: "
  read ans
  mkdir -p  $ans
}}


cmd show_help ${{
        bat ~/.config/lf/maps
    }}

cmd mkFile ${{
  printf "File Name: "
  read ans
  $EDITOR $ans
}}

# set wallpaper with feh
cmd setwallpaper %cp "$f" ~/.config/wall.png && feh -bg-fill ~/.config/wall.png 
cmd setwallpaper %cp "$f" ~/.config/wall.png && xwallpaper --zoom "$f"

# use broot to jump to a folder
cmd broot_jump ${{
  f=$(mktemp)
  res="$(broot --outcmd $f && cat $f | sed 's/cd //')"
  rm -f "$f"
  if [ -f "$res" ]; then
    cmd="select"
  elif [ -d "$res" ]; then
    cmd="cd"
  fi
  lf -remote "send $id $cmd \"$res\""
}}

cmd open_config  ${{
  $EDITOR $(bookmenu -b ~/.config/bookmenu/configs -f fzf -o)
}}

# you can use fzf
cmd fzf_jump ${{
  res="$(find . -maxdepth 3 | fzf --reverse --header='Jump to location')"
  if [ -f "$res" ]; then
    cmd="select"
  elif [ -d "$res" ]; then
    cmd="cd"
  fi
  lf -remote "send $id $cmd \"$res\""
}}

