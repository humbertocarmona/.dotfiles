# bindings
# First remove some defaults


# File Openers
map ee $$editor "$f"
map u $view "$f"
map V push :!nvim<space>

# archive mappings
map az zip
map at tar
map ag targz
map ab targz
map au unarchiv


# use enter for shell commands
# trash mappings
map dd cut
map dD delete
map <delete> trash
map tt trash
map tc clear_trash
map tr restore_trash

# dedicated keys for file opener actions
map x &xdg-open $f
map X $mimeopen --ask $f

# basic functions
map . set hidden!
map p paste
map y copy
map mf mkFile
map md mkDir
map ch chMod
map bg setwallpaper
map o open_config
map br $ed
map r rename
map h top
map l bottom
map R reload
map C clear
map u unselect

# Dragon Mapping
map dr dragon
map ds dragon-stay
map di dragon-individual
map dm mvdragon
map dc cpdragon
map dl dlfile

# movement
map gtr cd ~/.local/share/Trash/files

map gm cd ~/Music
map gv cd ~/Videos
map gp cd ~/Pictures
map gw cd ~/Pictures/Wallpapers

map gD cd ~/Documents
map gd cd ~/Downloads
map ge cd ~/Desktop

map gc.  cd ~/.config
map gcl cd ~/.config/lf
map gcp cd ~/.config/polybar
map gcb cd ~/.config/bspwm
map gcu cd ~/.config/pulse
map gcd cd ~/.dotfiles

map gl cd ~/.local
map ge cd /etc
map gu. cd /usr
map gus cd /usr/share
map gum cd /run/media/humberto

map j broot_jump


map s? show_help

