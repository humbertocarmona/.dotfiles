[colors]
background = #611e1e1e
background-alt = #611e1e1e
foreground = #ffffffff
foreground-alt = ${xrdb:color7:#222}
primary = #1b9fc6
secondary = #ffffff
alert = #bd2c40

[bar/example]
monitor = ${env:MONITOR}
bottom = false
width = 100%
height = 20
offset-x = 0.0%
offset-y = 0.%
radius = 0.0
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 2
; line-color = #00564d
border-size = 0
; border-color = #0D00564d
padding-left = 0
padding-right = 0
module-margin-left = 0
module-margin-right = 0
font-0 = JuliaMono:style=Regular:pixelsize=10
font-1 = JuliaMono:style=Regular:pixelsize=10
font-2 = Font Awesome 6 Free:pixelsize=10
font-3 = Font Awesome 6 Brands:pixelsize=10
font-4 = Font Awesome 6 Free:pixelsize=10
font-5 = Font Awesome 6 Brands:pixelsize=10
font-6 = MesloLGS NF:pixelsize=10
font-7 = MesloLGS NF:pixelsize=10
font-8 = MesloLGS NF:pixelsize=10
font-9 = MesloLGS NF:pixelsize=10
modules-left = bspwm 
modules-center = polybar-windows date pacman-updates
modules-right =  running-screen wlan bluetooth pavu alsa powermenu
separator = "  "
tray-position = none
; tray-padding = 2
; tray-background = $0063ff
wm-restack = bspwm
; override-redirect = true
; scroll-up = bspwm-desknext
; scroll-down = bspwm-deskprev
cursor-click = pointer
eursor-scroll = ns-resize

[module/xkeyboard]
type = internal/xkeyboard
label-layout-foreground = #ffffff
label-layout = %name% %icon%
layout-icon-default = :) 
layout-icon-0 = us#U
layout-icon-1 = us-acentos#U1
click-left =  switch

[module/pacman-updates]
type = custom/script
exec = checkupdates | wc -l
interval = 1000
label = Updates: %output%
format-foreground = ${colors.foreground}
format-background = ${colors.background}
format-prefix = "Ôćõ "
format-prefix-foreground = #ffbb00
; format-prefix-background = #ffbb00

[module/polybar-windows]
type = custom/script
exec = ~/.config/polybar/scripts/polybar-windows.sh 
format = <label>
format-prefix-foreground = #ffbb00
label = %output%
label-padding = 1
interval = 1

[module/bspwm]
type = internal/bspwm
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false
ws-icon-0 = I;Ôčź
ws-icon-1 = II;ÔĀĄ
ws-icon-2 = III;ÔČ®
ws-icon-3 = IV;Ôćė
ws-icon-4 = V;Ôáľ
ws-icon-5 = VI;ÔáĀ
ws-icon-6 = VII;ÔÖľ
ws-icon-7 = VIII;ÔÖľ
ws-icon-8 = IX;ÔÖľ
ws-icon-9 = X;ÔÖľ
ws-icon-default = X
separator = | 
label-focused = %icon%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 1
label-occupied = %icon%
label-occupied-padding = 1
label-urgent = %icon%!
label-urgent-background = ${colors.alert}
label-urgent-padding = 1
;label-empty = %index%
label-empty = %icon%
label-empty-foreground = #ffffff
label-empty-padding = 1
; Separator in between workspaces
label-separator = ""

[module/wlan]
type = internal/network
interface = wlp3s0
interval = 3.0
format-connected = <ramp-signal> <label-connected>
label-connected = %essid%
format-disconnected = _
ramp-signal-1 = _
ramp-signal-2 = Ôáę 
ramp-signal-3 = Ôáę
ramp-signal-4 = Ôáę
ramp-signal-5 = Ôáę
ramp-signal-foreground = ${colors.foreground}
; format-connected-underline = #9f78e1
; format-disconnected = <label-disconnected>
; format-disconnected-underline = ${self.format-connected-underline}
; label-disconnected = %ifname% disconnected
; label-disconnected-foreground = ${colors.foreground-alt}

[module/date]
type = internal/date
interval = 1
date = "%A %d/%m"
time = "%H:%M "
format-prefix = " ÔÄó "
format-prefix-foreground = #0a6cf5 
label = %date% %time%
; date-alt = "%A %d-%m-%Y"
; time-alt = "%H:%M:%S "
; format-foreground = #0a6cf5 
; ${colors.foreground-alt}
; format-underline = #0a6cf5
; format-underline =#f7347a

[module/alsa]
type = internal/alsa
format-volume = <label-volume> <bar-volume>
label-volume = "ÔÄ®"
label-volume-foreground = ${root.foreground}
format-muted-prefix = "Óąā"
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted
bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}


[module/powermenu]
type = custom/menu
expand-right = true
format-spacing = 1
label-open = ÔÄĎ
label-open-foreground = ${colors.secondary}
label-close = ÔÄĎ cancel
label-close-foreground = ${colors.secondary}
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = systemctl reboot
menu-0-1 = logout
menu-0-1-exec = bspc quit
menu-0-2 = poweroff
menu-0-2-exec = systemctl poweroff

[settings]
screenchange-reload = true
; compositing-background = xor
; compositing-background = screen
; compositing-foreground = source
; compositing-border = over
; seudo-transparency = true

[global/wm]
margin-top = 0
margin-bottom = 0

# my oun

[module/running-screen]
type = custom/script
exec = ~/.config/polybar/scripts/running-screen.sh
format = <label>
format-prefix-foreground = #ffbb00
label = %output%
label-padding = 1
interval = 1

[module/pavu]
type = custom/script
exec= echo "1"
click-left = pavucontrol &
format = <label>
label = "Ô¶Ņ -"
label-padding = 0

[module/bluetooth]
type = custom/script
exec = rofi-bluetooth --status | awk {'print $1'}
interval = 1
click-left = blueman-manager &



