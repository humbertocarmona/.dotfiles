#!/bin/sh

# A dmenu wrapper script for system functions.

##  CREDITS TO >  LUKE SMITH  <lukesmith.xyz>


case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case "$(printf "рҹ”’ lock\nрҹҡӘ leave dwm\nвҷ»пёҸ renew dwm\nрҹҗ» hibernate\nрҹ’Ө sleep\nрҹ”ғ reboot\nрҹ–ҘпёҸshutdown\nрҹ“ә display off" | dmenu -i -p 'Action: ')" in
	'рҹ”’ lock') slock ;;
	'рҹҡӘ leave dwm') kill -TERM "$(pgrep -u "$USER" "\bdwm$")" ;;
	'вҷ»пёҸ renew dwm') kill -HUP "$(pgrep -u "$USER" "\bdwm$")" ;;
	'рҹҗ» hibernate') slock $ctl hibernate ;;
	'рҹ’Ө sleep') slock $ctl suspend ;;
	'рҹ”ғ reboot') $ctl reboot ;;
	'рҹ–ҘпёҸshutdown') $ctl poweroff ;;
	'рҹ“ә display off') xset dpms force off ;;
	*) exit 1 ;;
esac
