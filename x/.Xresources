xterm*selectToClipboard: true
xterm*disallowedWindowOps: 20,21,SetXProp
*.font:	JuliaMono:pixelsize=25:antialias=true:autohint=true;
*.fontalt0:Hack Nerd Font:pixelsize=24:antialias=true:autohint=true;
/* *.fontalt1:JoyPixels:pixelsize=24:antialias=true:autohint=true; */
*.alpha: 0.90
!jellybeans
*.background: #151515
*.foreground: #ffffff
*.cursorColor: #d26939
! black
*.color0: #888888
*.color8: #525252
! red
*.color1: #cf6a4c
*.color9: #ff9d80
! green
*.color2: #99ad6a
*.color10: #c3e6ad
! yellow
*.color3: #fad07a
*.color11: #ffefbf
! blue
*.color4: #8197bf
*.color12: #accaff
! magenta
*.color5: #8787af
*.color13: #c4c4ff
! cyan
*.color6: #8fbfdc
*.color14: #80bfaf
! white
*.color7: #888888
*.color15: #e8e8d3


