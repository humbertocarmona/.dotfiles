#! /usr/bin/zsh

d=0  # delete
if [[ "$@" =~ (^|[[:space:]])"-d"($|[[:space:]]) ]] ; then
    d=1
fi

n=0  # do nothing 
if [[ "$@" =~ (^|[[:space:]])"-n"($|[[:space:]]) ]] ; then
    n=1
fi

if [ $n -eq 1 ]; then
    echo "dry run"
fi

if [ $d -eq 1 ]; then
    echo "deleting"
fi

for f in "$@"; do
  if [[ ( $f != "-d" ) && ( $f != "-n" ) ]]; then
    echo "compressing "$f
    if [ $n -eq 0 ]; then
       tar -cvf $f.tar $f
       if [ $d -eq 1 ]; then
         echo "deleting "$f
         rm -rf $f
       fi
    fi
  fi
done;
