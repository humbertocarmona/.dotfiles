#!/bin/sh

if [ $# -gt 0 ]; then
    full_path=$1
else
    full_path=$(find -L ~/packages/julias ~/packages/suckless ~/.config ~/.local  \
        -maxdepth 2 -type d \
        \( -regex ".+include.+" -o \
        -regex ".+share.+" -o \
        -regex ".+lib.+" -o \
        -regex ".+include.+" -o \
        -regex ".+.git" -o \
        -regex ".+Cache.+" -o \
        -regex ".+LICENSE.+" -o \
        -regex ".+log.+" \) -prune -o -print | fzf)
fi

if [ -z $full_path ]; then
    exit 0
fi

sesssion_name=$(basename "$full_path" | tr . _)

if [ -z $TMUX ]; then
    if ! tmux has-session -t $sesssion_name; then
        tmux new-session -s $sesssion_name  -d -c $full_path 
    fi
    tmux attach -t $sesssion_name
fi
