! clear all that is going to be changed
clear control
clear lock
clear mod4

! caps_loc to Control_L
keycode 66 = Control_L

! control_R to Super_L (for ibm keyboard)
keycode 105 = Super_L

! fn-caps/scroll Lock to  to caps
keycode 78 = Caps_Lock

! now add the proper functions
add control = Control_L Control_R 
add lock = Caps_Lock
add mod4 = Super_L
