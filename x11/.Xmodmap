! clear all that is going to be changed
clear control
clear lock
clear mod4

! ibm crtl-l to Super_L
keycode 37 = Super_L

! caps_loc to Control_R
keycode 66 = Control_L

! ibm ctrl-r to Super_L
keycode 105 = Super_L

! right menu key is Super_L
! keycode 135 = Super_L

! fn-caps/scroll Lock to  to caps
keycode 78 = Caps_Lock

! now add the proper functions
add control = Control_L Control_R 
add lock = Caps_Lock
add mod4 = Super_L
